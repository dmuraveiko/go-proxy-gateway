PROXY_HTTP_ADDR=:8080
PROXY_DATABASE_URL=postgres://proxy:proxy@127.0.0.1:5432/proxy?sslmode=disable
PROXY_DB_MAX_CONNS=32
PROXY_NATS_URL=nats://127.0.0.1:4222
PROXY_NATS_CREDS_FILE=
PROXY_NATS_CA_CERT=
PROXY_NATS_CLIENT_CERT=
PROXY_NATS_CLIENT_KEY=
PROXY_COMMANDS_STREAM=PROXY_COMMANDS
PROXY_RESULTS_STREAM=PROXY_RESULTS
PROXY_EVENTS_STREAM=PROXY_EVENTS
PROXY_DLQ_STREAM=PROXY_DLQ
PROXY_STREAM_REPLICAS=3
PROXY_STREAM_MAX_BYTES=10737418240
PROXY_MAX_MESSAGE_BYTES=2097152
PROXY_COMMAND_SUBJECT=proxy.commands.>
PROXY_COMMAND_DURABLE=proxy-gateway
PROXY_ACK_WAIT=1m
PROXY_MAX_ACK_PENDING=1024
PROXY_FETCH_BATCH=64
PROXY_OUTBOX_WORKERS=4
PROXY_RESULT_PREFIX=proxy.results
PROXY_EVENT_PREFIX=proxy.events
PROXY_DLQ_PREFIX=proxy.dlq
PROXY_REQUIRE_SIGNATURE=true
PROXY_SIGNING_PRIVATE_KEY_FILE=secrets/proxy.ed25519
PROXY_VERIFY_PUBLIC_KEYS=
# key-id=allowed.type|allowed.prefix.*;other-key-id=another.type
PROXY_KEY_PERMISSIONS=
PROXY_WORKERS=16
PROXY_REQUEST_TIMEOUT=30s
PROXY_SHUTDOWN_TIMEOUT=30s
PROXY_RETENTION=720h
PROXY_AUTO_MIGRATE=false

# Optional example integration: blockchain.transaction_status.get:v1
PROXY_TRANSACTION_STATUS_ENDPOINT=
PROXY_PROVIDER_API_KEY_HEADER=Authorization
PROXY_PROVIDER_API_KEY=
PROXY_PROVIDER_RPS=20

# Optional generic HMAC webhook adapter
PROXY_WEBHOOK_PROVIDER=
PROXY_WEBHOOK_SECRET=
# provider_type=internal.type;another_provider_type=another.internal.type
PROXY_WEBHOOK_EVENT_TYPES=
