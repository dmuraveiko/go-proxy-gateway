PROXY_ID=proxy-main
PROXY_INSTANCE_ID=proxy-main-1
PROXY_HTTP_ADDR=:8080
PROXY_PUBLIC_BASE_URL=https://proxy.example.com
PROXY_DATABASE_URL=postgres://proxy:proxy@127.0.0.1:5432/proxy?sslmode=disable
PROXY_DB_MAX_CONNS=32
PROXY_NATS_URL=nats://127.0.0.1:4222
PROXY_NATS_CREDS_FILE=
PROXY_NATS_CA_CERT=
PROXY_NATS_CLIENT_CERT=
PROXY_NATS_CLIENT_KEY=

PROXY_REQUIRE_SIGNATURE=true
PROXY_SIGNING_PRIVATE_KEY_FILE=secrets/proxy.ed25519
# client-a=BASE64_RAW_ED25519_PUBLIC_KEY;client-b=BASE64_RAW_ED25519_PUBLIC_KEY
PROXY_CLIENT_PUBLIC_KEYS=
PROXY_ALLOWED_CLIENTS=client-a,client-b

PROXY_WORKERS=16
PROXY_DELIVERY_WORKERS=4
PROXY_MAX_MESSAGE_BYTES=8388608
PROXY_MAX_REQUEST_BYTES=4194304
PROXY_MAX_RESPONSE_BYTES=4194304
PROXY_REQUEST_TIMEOUT=30s
PROXY_MAX_REQUEST_TIMEOUT=2m
PROXY_DISPATCH_LEASE=3m
PROXY_DELIVERY_RETRY=1s
PROXY_SHUTDOWN_TIMEOUT=30s

PROXY_DEFAULT_HOST_RPS=20
PROXY_DEFAULT_HOST_CONCURRENCY=8
# host=rps:concurrency;host:port=rps:concurrency
PROXY_HOST_LIMITS=api.example.com=5:2

PROXY_WEBHOOK_MAX_BODY_BYTES=4194304
PROXY_WEBHOOK_RESPONSE_TIMEOUT=10s
PROXY_RETENTION=720h
# 0 means unknown operations are never removed automatically.
PROXY_UNKNOWN_RETENTION=0
PROXY_CLEANUP_INTERVAL=1h
PROXY_AUTO_MIGRATE=false
